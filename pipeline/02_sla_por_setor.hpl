<?xml version="1.0" encoding="UTF-8"?>
<!--
  Apache Hop 2.17 Pipeline: 02 - SLA por Setor (CNAE)
  OLAP: Medida Calculada — media de dias abertura->arquivamento por CNAE.
  Como as datas estao como string DD/MM/YYYY, o SQL calcula o diff diretamente.
-->
<pipeline>
  <info>
    <name>02_sla_por_setor</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Tempo medio de resolucao (SLA) por setor CNAE</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>DB_PATH</name>
        <default_value>../output/procon.db</default_value>
        <description>Caminho para o banco SQLite</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2025/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/01/01 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAAAAMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>

  <notepads/>

  <order>
    <hop>
      <from>Table Input - SLA por setor</from>
      <to>Table Output - sla_por_setor</to>
      <enabled>Y</enabled>
    </hop>
  </order>

  <!--
    Estrategia: fazer TODO o calculo no SQL do SQLite.
    SQLite suporta julianday() para diff de datas em string ISO.
    Convertemos DD/MM/YYYY -> YYYY-MM-DD via substr/replace no SQL.
  -->
  <transform>
    <name>Table Input - SLA por setor</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>procon_sqlite</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>
SELECT
    COALESCE(NULLIF(TRIM(DescricaoCNAE),''), NULLIF(TRIM(CNAE),''), 'Nao informado') AS setor,
    ROUND(AVG(
        julianday(DataArquivamento) - julianday(DataAbertura)
    ), 2) AS media_dias_resolucao,
    COUNT(*) AS total_reclamacoes
FROM staging_reclamacoes
WHERE DataAbertura IS NOT NULL AND LENGTH(TRIM(DataAbertura)) >= 10
  AND DataArquivamento IS NOT NULL AND LENGTH(TRIM(DataArquivamento)) >= 10
  AND (julianday(DataArquivamento) - julianday(DataAbertura)) > 0
  AND COALESCE(NULLIF(TRIM(DescricaoCNAE),''), NULLIF(TRIM(CNAE),''), 'NULL') != 'NULL'
  AND COALESCE(NULLIF(TRIM(DescricaoCNAE),''), NULLIF(TRIM(CNAE),''), 'Nao informado') != 'Nao informado'
GROUP BY COALESCE(NULLIF(TRIM(DescricaoCNAE),''), NULLIF(TRIM(CNAE),''), 'Nao informado')
ORDER BY media_dias_resolucao DESC
    </sql>
    <variables_active>Y</variables_active>
    <attributes/>
    <GUI>
      <xloc>80</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Table Output - sla_por_setor</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>1000</commit>
    <connection>procon_sqlite</connection>
    <fields>
</fields>
    <ignore_errors>N</ignore_errors>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <specify_fields>N</specify_fields>
    <table>sla_por_setor</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>Y</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI>
      <xloc>400</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
