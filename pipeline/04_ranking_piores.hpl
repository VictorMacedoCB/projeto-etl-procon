<?xml version="1.0" encoding="UTF-8"?>
<!--
  Apache Hop 2.17 Pipeline: 04 - Ranking das Piores Empresas
  OLAP: Slice (Atendida='N') + Ranking por volume.
  Surrogate Key: RadicalCNPJ.
-->
<pipeline>
  <info>
    <name>04_ranking_piores</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Top 10 empresas com mais reclamacoes nao atendidas - Slice + Rank OLAP</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>DB_PATH</name>
        <default_value>../output/procon.db</default_value>
        <description>Caminho para o banco SQLite</description>
      </parameter>
      <parameter>
        <name>TOP_N</name>
        <default_value>10</default_value>
        <description>Quantidade de empresas no ranking</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2025/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/01/01 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAAAAMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>

  <notepads/>

  <order>
    <hop>
      <from>Table Input - ranking</from>
      <to>Add Sequence - posicao</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Add Sequence - posicao</from>
      <to>Table Output - ranking_piores_empresas</to>
      <enabled>Y</enabled>
    </hop>
  </order>

  <transform>
    <name>Table Input - ranking</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>procon_sqlite</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>
-- SLICE: somente Atendida='N'
-- SURROGATE KEY: RadicalCNPJ (8 digitos do CNPJ)
-- MELHOR NOME: NomeFantasia > RazaoSocial > RazaoSocialRFB > CNPJ
SELECT
    TRIM(RadicalCNPJ) AS radical_cnpj,
    COALESCE(
        NULLIF(TRIM(strNomeFantasia), ''),
        NULLIF(TRIM(strRazaoSocial),  ''),
        NULLIF(TRIM(RazaoSocialRFB),  ''),
        TRIM(RadicalCNPJ)
    ) AS nome,
    COUNT(*) AS nao_atendidas
FROM staging_reclamacoes
WHERE TRIM(UPPER(Atendida)) = 'N'
  AND RadicalCNPJ IS NOT NULL
  AND TRIM(RadicalCNPJ) != ''
  AND UPPER(TRIM(RadicalCNPJ)) != 'NULL'
  AND UPPER(TRIM(RadicalCNPJ)) != 'NAO INFORMADO'
  AND UPPER(TRIM(COALESCE(
        NULLIF(TRIM(strNomeFantasia), ''),
        NULLIF(TRIM(strRazaoSocial),  ''),
        NULLIF(TRIM(RazaoSocialRFB),  ''),
        TRIM(RadicalCNPJ)
      ))) != 'NULL'
  AND UPPER(TRIM(COALESCE(
        NULLIF(TRIM(strNomeFantasia), ''),
        NULLIF(TRIM(strRazaoSocial),  ''),
        NULLIF(TRIM(RazaoSocialRFB),  ''),
        TRIM(RadicalCNPJ)
      ))) != 'NAO INFORMADO'
GROUP BY TRIM(RadicalCNPJ)
ORDER BY nao_atendidas DESC
LIMIT 10
    </sql>
    <variables_active>Y</variables_active>
    <attributes/>
    <GUI>
      <xloc>80</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Add Sequence - posicao</name>
    <type>Sequence</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection/>
    <counter_name/>
    <increment_by>1</increment_by>
    <max_value>999999999</max_value>
    <seqname>SEQ_POSICAO</seqname>
    <start_at>1</start_at>
    <use_counter>Y</use_counter>
    <use_database>N</use_database>
    <valuename>posicao</valuename>
    <attributes/>
    <GUI>
      <xloc>360</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Table Output - ranking_piores_empresas</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>100</commit>
    <connection>procon_sqlite</connection>
    <fields>
</fields>
    <ignore_errors>N</ignore_errors>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <specify_fields>N</specify_fields>
    <table>ranking_piores_empresas</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>Y</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI>
      <xloc>600</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
